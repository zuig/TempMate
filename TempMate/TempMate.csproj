<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net5.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>TempMate</RootNamespace>
    <AssemblyName>TempMate</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>AnyCPU;x64</Platforms>

    <Version>1.0.0</Version>
    <FileVersion>1.0.0.0</FileVersion>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <Authors>TempMate</Authors>
    <Product>TempMate</Product>
    <Description>桌面悬浮温度监控小工具</Description>
    <ApplicationIcon>..\TempMate.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- 使用 NuGet 上的 LibreHardwareMonitorLib 0.9.0，它的所有依赖（含
         System.IO.FileSystem.AccessControl / System.Security.AccessControl 等）
         会被 NuGet 自动还原，避免直接引用 .NET Framework 版 DLL 导致的
         运行时 MissingMethodException。 -->
    <PackageReference Include="LibreHardwareMonitorLib" Version="0.9.0" />
  </ItemGroup>

</Project>
